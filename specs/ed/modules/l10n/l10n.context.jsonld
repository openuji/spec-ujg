{
  "@context": {
    "@version": 1.1,

    "ujgl10n": "https://ujg.specs.openuji.org/ed/ns/l10n#",
    "l10n": "https://ujg.specs.openuji.org/ed/ns/l10n#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "MessageBundle": "ujgl10n:MessageBundle",

    "copyRef": {
      "@id": "ujgl10n:copyRef",
      "@type": "@id"
    },
    "namespace": "ujgl10n:namespace",
    "messageKey": "ujgl10n:messageKey",
    "defaultLocale": "ujgl10n:defaultLocale",
    "fallbackLocales": {
      "@id": "ujgl10n:fallbackLocales",
      "@container": "@set"
    },
    "rtl": "ujgl10n:rtl",
    "locales": {
      "@id": "ujgl10n:locales",
      "@type": "@json"
    },
    "targetLocale": {
      "@id": "ujgl10n:targetLocale",
      "@type": "xsd:language"
    },
    "l10n:targetLocale": {
      "@id": "ujgl10n:targetLocale",
      "@type": "xsd:language"
    }
  }
}
