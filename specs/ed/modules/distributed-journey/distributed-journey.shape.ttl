@prefix ujg: <https://ujg.specs.openuji.org/ed/ns/core#> .
@prefix ujgaction: <https://ujg.specs.openuji.org/ed/ns/action#> .
@prefix ujgartifact: <https://ujg.specs.openuji.org/ed/ns/artifact#> .
@prefix ujgdist: <https://ujg.specs.openuji.org/ed/ns/distributed-journey#> .
@prefix ujgdistshape: <https://ujg.specs.openuji.org/ed/ns/distributed-journey.shape#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

ujgdistshape:AuthorityShape a sh:NodeShape ;
  sh:targetClass ujgdist:Authority ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgdist:origin ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

ujgdistshape:DistributedOperationShape a sh:NodeShape ;
  sh:targetClass ujgdist:DistributedOperation ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgdist:operationActionRef ;
    sh:class ujgaction:Action ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:sourceAuthorityRef ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:targetAuthorityRefs ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
  ] ;

  sh:property [
    sh:path ujgdist:protocolMessageRefs ;
    sh:class ujgdist:ProtocolMessage ;
    sh:nodeKind sh:IRI ;
  ] ;

  sh:property [
    sh:path ujgdist:propagationStateRef ;
    sh:class ujgdist:PropagationState ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] .

ujgdistshape:DistributedArtifactShape a sh:NodeShape ;
  sh:targetClass ujgdist:DistributedArtifact ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgdist:sourceAuthorityRef ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:targetAuthorityRefs ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
  ] ;

  sh:property [
    sh:path ujgdist:propagationStateRef ;
    sh:class ujgdist:PropagationState ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] .

ujgdistshape:ProtocolMessageShape a sh:NodeShape ;
  sh:targetClass ujgdist:ProtocolMessage ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgdist:sourceAuthorityRef ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:targetAuthorityRefs ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:propagationStateRef ;
    sh:class ujgdist:PropagationState ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] .

ujgdistshape:PortabilityClaimShape a sh:NodeShape ;
  sh:targetClass ujgdist:PortabilityClaim ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgdist:sourceAuthorityRef ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:targetAuthorityRefs ;
    sh:class ujgdist:Authority ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:portabilityStatusRef ;
    sh:class ujgdist:PortabilityStatus ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:portabilityGapRefs ;
    sh:class ujgdist:PortabilityGap ;
    sh:nodeKind sh:IRI ;
  ] .

ujgdistshape:PortabilityGapShape a sh:NodeShape ;
  sh:targetClass ujgdist:PortabilityGap ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgdist:portabilityGapKindRef ;
    sh:class ujgdist:PortabilityGapKind ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

ujgdistshape:ConsistencyExpectationShape a sh:NodeShape ;
  sh:targetClass ujgdist:ConsistencyExpectation ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:path ujgdist:consistencySubjectRef ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:counterpartRef ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:path ujgdist:consistencyModeRef ;
    sh:class ujgdist:ConsistencyMode ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

ujgdistshape:PropagationStateShape a sh:NodeShape ;
  sh:targetClass ujgdist:PropagationState ;
  sh:nodeKind sh:IRI .

ujgdistshape:PortabilityStatusShape a sh:NodeShape ;
  sh:targetClass ujgdist:PortabilityStatus ;
  sh:nodeKind sh:IRI .

ujgdistshape:PortabilityGapKindShape a sh:NodeShape ;
  sh:targetClass ujgdist:PortabilityGapKind ;
  sh:nodeKind sh:IRI .

ujgdistshape:ConsistencyModeShape a sh:NodeShape ;
  sh:targetClass ujgdist:ConsistencyMode ;
  sh:nodeKind sh:IRI .
