---
import type { CodeLanguage } from 'astro';
import { Code } from 'astro:components';
import { ChevronDown, Copy } from 'lucide-react';

interface Props {
  code: string;
  lang?: CodeLanguage;
  id?: string;
  collapsible?: boolean;
}

const { code, lang = 'text', id, collapsible = false } = Astro.props;
const wrapperClass = collapsible
  ? 'code-block-wrapper code-block-wrapper--collapsible is-collapsed'
  : 'code-block-wrapper';
---

<div class={wrapperClass} id={id} data-code-collapsible={collapsible ? 'true' : undefined}>
  <div class="code-header">
    <span class="code-language">
      {lang}
    </span>
    <button class="copy-btn" aria-label="Copy code" data-code={code}>
      <div class="copy-btn-icon">
        <Copy className="copy-icon" />
      </div>
    </button>
  </div>
  <div class="code-content">
    <div class="code-theme code-theme--light">
      <Code code={code} lang={lang} theme="github-light" wrap={false} />
    </div>
    <div class="code-theme code-theme--dark">
      <Code code={code} lang={lang} theme="github-dark" wrap={false} />
    </div>
  </div>
  {
    collapsible && (
      <button
        class="code-collapse-toggle"
        type="button"
        aria-expanded="false"
        aria-label="Show full code block"
      >
        <span class="code-collapse-toggle-label">SHOW FULL</span>
        <ChevronDown className="code-collapse-toggle-chevron" aria-hidden="true" />
      </button>
    )
  }
</div>

<script>
  function setupCopyButtons() {
    const buttons = document.querySelectorAll('.copy-btn');

    buttons.forEach((btn) => {
      // Remove old listener if present (in case of re-runs)
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      newBtn.addEventListener('click', async () => {
        const code = newBtn.getAttribute('data-code') || '';

        try {
          await navigator.clipboard.writeText(code);
        } catch (err) {
          console.error('Failed to copy code:', err);
        }
      });
    });
  }

  function setupCollapsibleCodeBlocks() {
    const toggles = document.querySelectorAll('.code-collapse-toggle');

    toggles.forEach((toggle) => {
      const newToggle = toggle.cloneNode(true) as HTMLButtonElement;
      toggle.parentNode?.replaceChild(newToggle, toggle);

      const wrapper = newToggle.closest('.code-block-wrapper--collapsible');
      const label = newToggle.querySelector('.code-collapse-toggle-label');

      if (!wrapper || !label) return;

      const setExpanded = (expanded: boolean) => {
        wrapper.classList.toggle('is-collapsed', !expanded);
        wrapper.classList.toggle('is-expanded', expanded);
        newToggle.setAttribute('aria-expanded', String(expanded));
        newToggle.setAttribute(
          'aria-label',
          expanded ? 'Collapse code block' : 'Show full code block'
        );
        label.textContent = expanded ? 'COLLAPSE' : 'SHOW FULL';
      };

      setExpanded(false);

      newToggle.addEventListener('click', () => {
        setExpanded(newToggle.getAttribute('aria-expanded') !== 'true');
      });
    });
  }

  // Run on initial load
  setupCopyButtons();
  setupCollapsibleCodeBlocks();

  // Run on view transitions navigation
  document.addEventListener('astro:page-load', () => {
    setupCopyButtons();
    setupCollapsibleCodeBlocks();
  });
</script>
