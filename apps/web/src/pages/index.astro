---
import HomeLayout from '@/layouts/HomeLayout.astro';
import Hero from '@/components/astro/Hero.astro';
import Panel from '@/components/astro/Panel.astro';
import Card from '@/components/astro/Card.astro';
import CTA from '@/components/astro/CTA.astro';
---

<HomeLayout title="User Journey Graph Specifications">
  <Hero
    title="User Journey Graph (UJG)"
    description="UJG is a <b>W3C community-driven standard</b> that provides a <b>common language</b> for user journeys. It enables teams to <b>design, share, execute, and verify</b> journeys across tools and platforms."
    pills={['UJG • W3C Community Group']}
    actions={[
      {
        label: 'Join UJG W3C community group',
        href: 'https://www.w3.org/community/ujg/join',
        primary: true,
      },
      { label: "Editor's Draft Workspace", href: '/ed' },
    ]}
  />

  <section class="flow">
    <div class="flow__header">
      <h2 class="font-medium">What's inside the UJG family</h2>
      <p>
        Each document focuses on a specific aspect of journey modeling. Together, they connect
        intent, execution, and measurement.
      </p>
    </div>
    <div class="flow__grid">
      <Card
        title="Architecture"
        description="Conceptual stack and core guiding principles."
        href="/ed/architecture"
      />
      <Card
        title="Graph"
        description="Journeys, states, transitions, nesting, and reusable navigation patterns."
        href="/ed/graph"
      />
      <Card
        title="Runtime"
        description="Data model for recording actual user behavior as causally ordered event chains."
        href="/ed/runtime"
      />
    </div>
    <a class="flow__cta" href="/ed">See all specs →</a>
  </section>

  <section class="card-grid roles">
    <Panel>
      <h2>How to read (by role)</h2>
      <div class="role-list">
        <div>
          <h4>Product / UX</h4>
          <p>Architecture → Graph → Metrics</p>
        </div>
        <div>
          <h4>Engineering</h4>
          <p>Architecture → Core → Graph → Runtime → Mapping</p>
        </div>
        <div>
          <h4>Analytics / Data</h4>
          <p>Architecture → Runtime → Mapping → Metrics</p>
        </div>
        <div>
          <h4>Tool builders</h4>
          <p>Core → Profiles → Runtime → Mapping</p>
        </div>
      </div>
    </Panel>

    <Panel variant="glow">
      <h2>Publishing model</h2>
      <p>
        UJG evolves in the Editor's Draft workspace. Technical Reports are immutable snapshots of
        documents the editors believe are reliable enough for community experimentation.
      </p>
      <ul>
        <li>Selected draft material captured at a point in time.</li>
        <li>Stable URL space for implementers.</li>
        <li>Publication does not mean every included part is final or stable.</li>
        <li>ED continues iterating alongside TR releases.</li>
      </ul>
    </Panel>
  </section>

  <CTA
    title="Participate"
    description="UJG is developed openly. Feedback, issues, and implementation reports are welcome."
    links={[
      { label: 'Adoption FAQ', href: '/adoption-faq' },
      { label: 'AI Governance', href: '/ai-governance-faq' },
      { label: 'Spec Governance', href: '/governance' },
      { label: 'Contributing', href: '/contributing' },
      {
        label: 'Issues / PRs',
        href: 'https://github.com/openuji/spec-ujg/issues',
        primary: true,
        target: '_blank',
      },
    ]}
  />
</HomeLayout>
